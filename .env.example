# ─── Base de Datos ──────────────────────────────────────────────
# SQLite (por defecto):
DATABASE_URL=sqlite:///./food_store.db
# PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/food_store_db

# ─── JWT ────────────────────────────────────────────────────────
SECRET_KEY=change_this_secret_key_for_production_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── MercadoPago (Sandbox) ─────────────────────────────────────
# OBTENER CREDENCIALES:
# 1. Crear cuenta en https://www.mercadopago.com.ar/developers/es
# 2. Ir a "Tus credenciales" -> "Credenciales de prueba"
# 3. Copiar el Access Token y Public Key aquí
# 4. Usar las tarjetas de prueba: https://www.mercadopago.com.ar/developers/es/docs/checkout-pro/additional-content/test-cards
MP_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXX
MP_PUBLIC_KEY=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_WEBHOOK_URL=https://your-ngrok.ngrok-free.dev/api/v1/pagos/webhook

# ─── Cloudinary ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz123

# ─── URLs ───────────────────────────────────────────────────────
VITE_FRONTEND_URL=http://localhost:5500
VITE_API_URL=http://localhost:8000
NGROK_URL=https://your-ngrok.ngrok-free.dev
